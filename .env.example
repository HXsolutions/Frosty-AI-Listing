# API Keys
OPENAI_API_KEY=sk-...
FIRECRAWL_API_KEY=fc-...

# Google Sheets
GOOGLE_SERVICE_ACCOUNT_FILE=service_account.json
GOOGLE_SHEET_ID=your_google_sheet_id_here

# App Settings
CONFIDENCE_THRESHOLD=0.75
APP_ENV=development       # Change to "production" on Railway

# Security
# Generate a strong random key: python -c "import secrets; print(secrets.token_hex(32))"
# Set this in Railway env vars — leave blank locally for dev
ADMIN_API_KEY=

# CORS — set to your Railway URL in production
# e.g. ALLOWED_ORIGIN=https://frosty-ai.up.railway.app
ALLOWED_ORIGIN=*
